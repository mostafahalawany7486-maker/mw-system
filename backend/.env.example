APP_NAME=Property Management System
APP_ENV=development
DEBUG=true

SECRET_KEY=replace-with-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60

DATABASE_URL=postgresql+psycopg2://pms_user:pms_password@db:5432/pms_db

BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./storage
MAX_UPLOAD_SIZE_MB=25

# Only used when STORAGE_BACKEND=azure_blob
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=pms-attachments

FIRST_ADMIN_EMAIL=admin@pms-demo.com
FIRST_ADMIN_PASSWORD=Admin@12345
